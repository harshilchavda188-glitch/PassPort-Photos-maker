PORT=5000
NODE_ENV=development

# MongoDB - Required: change to your MongoDB URI
# Local: mongodb://localhost:27017/passport-photos
# Atlas: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/passport-photos
MONGODB_URI=mongodb://localhost:27017/passport-photos

JWT_SECRET=
JWT_EXPIRE=7d

# Background Removal API Keys (optional - uses local fallback)
REMOVE_BG_API_KEY=
CLIPDROP_API_KEY=
REPLICATE_API_KEY=
DEFAULT_BG_TOOL=local

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
